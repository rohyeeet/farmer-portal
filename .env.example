# =========================================================================
# Farmer Portal — environment variables
# Copy this file to .env.local and fill in the values for your environment.
# Variables prefixed with NEXT_PUBLIC_ are bundled into the client build —
# never put secrets there.
# =========================================================================

# Backend base URL. Leave empty in dev so /api/* and /core/* are proxied to
# DEV_PROXY_TARGET below (configured in next.config.ts).
# Do NOT set this to https://backendtest.varahaag.com (or any remote host) while
# running `npm run dev` on http://localhost:3000 — the browser will send
# cross-origin POSTs and Django will reject them with "CSRF Failed: Origin checking
# failed - http://localhost:3000 does not match any trusted origins."
# In production this MUST be set to the canonical https://backend(test)?.varahaag.com URL.
NEXT_PUBLIC_API_BASE_URL=

# Google Maps browser API key — required to render the farm boundary map.
# Without this key the farm detail map falls back to a static area readout.
# Generate at https://console.cloud.google.com/apis/credentials and restrict
# the key by HTTP referrer to your deployed host(s).
NEXT_PUBLIC_GOOGLE_MAP_API_KEY=AIzaSyCjCnetS7AvWzQzTyHGkrjlgVCI26NbNS0

# Optional Google Cloud Map ID (from Map Management). Leave empty for default hybrid tiles.
NEXT_PUBLIC_GOOGLE_MAP_ID=

# Development-only API proxy. The Next dev server rewrites /api/* and
# /core/* to this host so the browser can call same-origin URLs without
# tripping CORS during local development.
DEV_PROXY_TARGET=https://backendtest.varahaag.com
